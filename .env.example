DJANGO_ENV=dev
SECRET_KEY=change-me
DEBUG=True

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=konglomerat
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
DB_CONN_MAX_AGE=60

ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

ACCESS_TOKEN_MINUTES=10
REFRESH_TOKEN_DAYS=7
JWT_COOKIE_SECURE=False
JWT_COOKIE_SAMESITE=Lax

APP_FORCE_HTTPS=False
REDIS_URL=redis://localhost:6379/0

# Google Gemini powers the business assistant. Leave blank to run the
# assistant on its scripted fallback answers instead.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=20
GEMINI_MAX_OUTPUT_TOKENS=400

USE_S3=False
USE_S3_FOR_STATIC=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_STATIC_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
AWS_S3_ENDPOINT_URL=
AWS_S3_VERIFY=True
AWS_QUERYSTRING_AUTH=True
AWS_S3_USE_SSL=True
