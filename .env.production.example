COMPOSE_PROJECT_NAME=konglamerat
APP_ENV_FILE=./.env
BACKEND_IMAGE=ghcr.io/konglomerat-platform/backend:main
HTTP_PORT=80

DJANGO_ENV=prod
SECRET_KEY=change-me
DEBUG=False

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=konglomerat
POSTGRES_USER=konglomerat
POSTGRES_PASSWORD=change-me
DB_CONN_MAX_AGE=60
POSTGRES_WAIT_TIMEOUT=60

ALLOWED_HOSTS=89.168.127.116,localhost,127.0.0.1,website-project.uz
CORS_ALLOWED_ORIGINS=https://website-project.uz
CSRF_TRUSTED_ORIGINS=https://website-project.uz

ACCESS_TOKEN_MINUTES=10
REFRESH_TOKEN_DAYS=7
JWT_COOKIE_SECURE=True
JWT_COOKIE_SAMESITE=Lax

APP_FORCE_HTTPS=True
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
REDIS_URL=redis://redis:6379/0

USE_S3=False
USE_S3_FOR_STATIC=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_STATIC_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
AWS_S3_ENDPOINT_URL=
AWS_S3_VERIFY=True
AWS_QUERYSTRING_AUTH=True
AWS_S3_USE_SSL=True
